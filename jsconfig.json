{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@/theme/section/*": ["./core/theme/section/*"],
      "@/theme/view/*": ["./core/theme/view/*"],
      "@/theme/item/*": ["./core/theme/item/*"],
      "@/theme/provider/*": ["./core/theme/provider/*"],
      "@/theme/*": ["./core/theme/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", ".next", "out", "build"]
}
